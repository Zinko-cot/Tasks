CORRECT_PIN = "1234"
balance = 5000.0

print("Welcome to the Smart Bank")
user_pin = input("Enter your password (PIN): ")


if user_pin == CORRECT_PIN:
    print("\nAvailable Operations:")
    print("1: Withdraw Cash")
    print("2: Check Balance")

    choice = input("Please select an operation (1 or 2): ").strip()

    if choice == "2":
        print(f"Your current balance is: {balance} EGP.")
        
   
    elif choice == "1":
        withdraw_amount = float(input("Enter the amount you want to withdraw: "))
        
        if withdraw_amount > balance:
            print("Sorry, your balance is insufficient.")
        else:
            balance -= withdraw_amount # خصم المبلغ من الرصيد
            print(f"Transaction completed successfully. Your remaining balance is: {balance} EGP.")
            
    else:
        print("Invalid choice, please try again.")


else:
    print("Incorrect PIN, transaction rejected.")
